{
  "name": "discord-mcp",
  "version": "0.1.0",
  "description": "Full-featured Discord MCP server",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "discord-mcp": "src/index.ts"
  },
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "test": "vitest run",
    "lint": "oxlint src",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "discord.js": "^14.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxlint": "latest",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
